# Environment Variables
# Copiar este archivo a .env y completar con tus valores

# API Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Model Configuration
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.1
DEVICE=cuda
PRECISION=float16
QUANTIZE=True
MAX_TOKENS=2048

# Temperature and Sampling
TEMPERATURE=0.7
TOP_P=0.95
TOP_K=50
REPETITION_PENALTY=1.2

# RAG Configuration
RAG_ENABLED=True
RAG_THRESHOLD=0.3

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ai_engine.log

# CORS (para acceso desde web)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://tu-dominio.com"]

# Redis (opcional, para caching)
REDIS_URL=redis://localhost:6379

# Database (opcional)
DATABASE_URL=sqlite:///./ai_engine.db
